{
	"schemaVersion": 1,
	"id": "dimtpcommand",
	"version": "${version}",
	"name": "DimTpCommand",
	"description": "Add /dimtp command, letting players teleport to any dimension at specified coordinates.",
	"authors": [
		"chenjunfu2"
	],
	"contact": {
		"homepage": "https://github.com/chenjunfu2/dimtpcommand-1.20.1",
		"sources": "https://github.com/chenjunfu2/dimtpcommand-1.20.1"
	},
	"license": "CC0-1.0",
	"icon": "assets/dimtpcommand/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"chenjunfu2.dimtpcommand.DimTpCommand"
		]
	},
	"mixins": [
		"dimtpcommand.mixins.json",
		{
			"config": "dimtpcommand.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.10",
		"minecraft": "~1.20.1",
